# Microsoft Azure AD App Registration
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Meeting organizer email (must be a user in the Azure AD tenant)
USER_ID=organizer@yourdomain.com

# Server config
PORT=3001

# CORS - comma-separated allowed origins
CORS_ORIGIN=http://localhost:4200

# Affinda resume parser
AFFINDA_API_KEY=your_affinda_api_key
AFFINDA_WORKSPACE=your_workspace_id
AFFINDA_DOCUMENT_TYPE=your_document_type_id
